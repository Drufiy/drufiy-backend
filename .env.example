# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: Supabase dashboard → Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...    # Service role key — NOT the anon key

# ── Kimi (OpenAI-compatible) ─────────────────────────────────────────────────
# Get from: platform.moonshot.cn
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxx
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6

# ── Fallback model (used if Kimi returns malformed JSON twice in a row) ───────
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxx

# ── GitHub OAuth App ─────────────────────────────────────────────────────────
# Get from: github.com/settings/developers → OAuth Apps → Drufiy
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=168
# Separate key for encrypting stored GitHub tokens. If omitted, JWT_SECRET is
# used for backward compatibility, but production should set this separately.
TOKEN_ENCRYPTION_KEY=

# ── Webhook automation ───────────────────────────────────────────────────────
WEBHOOK_RATE_LIMIT_MAX=60
WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=3600
FIX_BRANCH_PREFIX=prash/fix-run-

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Production: https://prashbydrufiy.vercel.app
# Update after Cloud Run deploy
PUBLIC_BACKEND_URL=http://localhost:8000

# ── Environment ───────────────────────────────────────────────────────────────
ENV=development
